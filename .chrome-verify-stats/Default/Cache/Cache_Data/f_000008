  const [{ data: students, error: studentsErr }, { data: latest, error: latestErr }, { data: daily, error: dailyErr }, { data: weekly, error: weeklyErr }] =
    await Promise.all([
      supabase.from('students').select('*').eq('is_active', true).order('joined_at'),
      supabase.from('latest_snapshot').select('*'),
      supabase.from('daily_delta').select('*'),
      supabase.from('weekly_delta').select('*'),
    ]);

  if (studentsErr) throw studentsErr;
  if (latestErr) throw latestErr;
  if (dailyErr) throw dailyErr;
  if (weeklyErr) throw weeklyErr;

  const latestMap = Object.fromEntries((latest ?? []).map((r) => [r.student_id, r]));
  const dailyMap = Object.fromEntries((daily ?? []).map((r) => [r.student_id, r]));
  const weeklyMap = Object.fromEntries((weekly ?? []).map((r) => [r.student_id, r]));

  return (students ?? []).map((s) => {
    const l = latestMap[s.id];
    const d = dailyMap[s.id];
    const w = weeklyMap[s.id];

    return {
      id: s.id,
      username: s.leetcode_username,
      displayName: s.display_name,
      joinedAt: s.joined_at,
      hasData: Boolean(l),
      easySolved: l?.easy_solved ?? 0,
      mediumSolved: l?.medium_solved ?? 0,
      hardSolved: l?.hard_solved ?? 0,
      totalSolved: l?.total_solved ?? 0,
      ranking: l?.ranking ?? null,
      solvedToday: d?.solved_today ?? 0,
      easyToday: d?.easy_today ?? 0,
      mediumToday: d?.medium_today ?? 0,
      hardToday: d?.hard_today ?? 0,
      solvedWeek: w?.solved_week ?? 0,
      easyWeek: w?.easy_week ?? 0,
      mediumWeek: w?.medium_week ?? 0,
      hardWeek: w?.hard_week ?? 0,
    };
  });
}

/** Removes a student from the leaderboard (their row only). */
export async function removeStudent(studentId) {
  const supabase = getSupabase();
  const { error } = await supabase.from('students').delete().eq('id', studentId);
  if (error) throw error;
}

